<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Car App Library: the WEATHER category + these permissions let the app
         host a MapWithContentTemplate and draw its hot-light dashboard on the
         car's custom Surface (Canvas) — without claiming the navigation surface.
         MAP_TEMPLATES (not NAVIGATION_TEMPLATES) keeps it out of the nav flow. -->
    <uses-permission android:name="androidx.car.app.MAP_TEMPLATES" />
    <uses-permission android:name="androidx.car.app.ACCESS_SURFACE" />

    <!-- Declares this as an Android Auto weather app: it draws a custom map/canvas
         dashboard via MapWithContentTemplate and hands navigation off to the
         active nav provider, without being a navigation app itself. -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kremeing">

        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

        <meta-data
            android:name="androidx.car.app.minCarApiLevel"
            android:value="1" />

        <!-- Phone home screen: native OpenStreetMap map of nearby stores,
             pins colored by hot-light status. The app's launcher entry. -->
        <activity
            android:name=".map.MapActivity"
            android:exported="true"
            android:theme="@style/Theme.Kremeing.Map">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Settings screen: notify radius slider + location/notification
             permissions and (when enabled) the push subscription. Reached from
             the map's overflow menu. -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- The Android Auto host binds to this service to drive the car UX. -->
        <service
            android:name=".car.KremeingCarAppService"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <category android:name="androidx.car.app.category.WEATHER" />
            </intent-filter>
        </service>

        <!-- Receives FCM hot-light pushes and posts the notification. -->
        <service
            android:name=".messaging.KremeingMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
